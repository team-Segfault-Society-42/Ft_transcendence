# ── General ──────────────────────────────────────────────────────────────────
DOMAIN=127.0.0.1

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_VERSION=18-alpine
POSTGRES_DB=transcendence
POSTGRES_USER=postgres_superuser
BACKEND_USER=backend_user

# ── 42 OAuth ─────────────────────────────────────────────────────────────────
FORTYTWO_CLIENT_ID=your_42_OAuth_id
FORTYTWO_CLIENT_SECRET=your_42_OAuth_Secret
FORTYTWO_REDIRECT_URI=http://127.0.0.1:1024/api/auth/42/callback
FRONTEND_OAUTH_SUCCESS_URL=http://127.0.0.1:1024/
VITE_OAUTH_42_START_URL=http://127.0.0.1:1024/api/auth/42

# ── 2FA ──────────────────────────────────────────────────────────────────────
TWO_FACTOR_URL=http://127.0.0.1:1024/two-factor
